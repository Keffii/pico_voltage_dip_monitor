          "query": "from(bucket: \"pico_voltage\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"voltage_baseline\")\n  |> filter(fn: (r) => r[\"_field\"] == \"baseline\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"baseline\")",
