          "query": "from(bucket: \"pico_voltage\")\n  |> range(start: -1m)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"voltage_median\")\n  |> filter(fn: (r) => r[\"_field\"] == \"voltage\")\n  |> last()\n  |> yield(name: \"last\")",
